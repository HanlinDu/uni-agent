# LMCache MP settings for single_node_v1_collocate_async_lmcache.sh.
#
# This file is intentionally separate from the original training entrypoint.
# The original single_node_v1_collocate_async.sh is not modified.

# ZMQ endpoint used by vLLM's LMCacheMPConnector.
LMCACHE_MP_BIND_HOST=127.0.0.1
LMCACHE_MP_CONNECTOR_HOST=tcp://127.0.0.1
LMCACHE_MP_PORT=5555

# LMCache HTTP frontend for inspection and metrics.
LMCACHE_HTTP_HOST=127.0.0.1
LMCACHE_HTTP_PORT=8080

# Local LMCache L1 capacity and chunking for this validation run.
# Keep the validation chunk small so short system prefixes can produce store metadata.
LMCACHE_L1_SIZE_GB=20
LMCACHE_CHUNK_SIZE=64

# Use worker-side gather/scatter transfer instead of CUDA IPC.
# CUDA IPC may fail in containerized Ray/vLLM workers without shared host IPC.
LMCACHE_MP_TRANSFER_MODE=engine_driven

# Logs written by the validation entrypoint.
LMCACHE_LOG_LEVEL=INFO
LMCACHE_LOG_DIR=/tmp/uni-agent-lmcache
LMCACHE_WAIT_TIMEOUT_SECONDS=120

# Keep validation scoped to the current run. Set True only for manual debugging.
LMCACHE_INCLUDE_SESSION_LOGS=False

# Validation mode:
# - epoch: verify explicit per-weight-update namespace advancement.
# - external_reuse: keep the model cache epoch fixed and require LMCache retrieve.
LMCACHE_VALIDATION_MODE=${LMCACHE_VALIDATION_MODE:-epoch}

# uni-agent managed extra prefix cache namespace.
# Update this value when rollout model weights should stop reusing old external KV.
LMCACHE_EXTRA_PREFIX_NAMESPACE=uni-agent-system-prefix
LMCACHE_EXTRA_PREFIX_MODEL_EPOCH=epoch0
